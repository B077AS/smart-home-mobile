{
  "name": "capacitor-app",
  "version": "1.0.0",
  "description": "An Amazing Capacitor App",
  "type": "module",
  "keywords": [
    "capacitor",
    "mobile"
  ],
  "scripts": {
    "start": "purgecss --css node_modules/@mdi/font/css/materialdesignicons.css --content \"src/**/*.html\" \"src/**/*.js\" --output src/css/icons.css && vite",
    "build": "purgecss --css node_modules/@mdi/font/css/materialdesignicons.css --content \"src/**/*.html\" \"src/**/*.js\" --output src/css/icons.css && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/camera": "latest",
    "@capacitor/core": "latest",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "latest",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@mdi/font": "^7.4.47"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "latest",
    "purgecss": "^8.0.0",
    "vite": "^5.4.21"
  },
